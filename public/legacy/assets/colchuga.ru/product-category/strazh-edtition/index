<script>
    $(document).ready(function () {
        $('#sort_select').on('change', function () {
            var order = $(this).val();
            sortByPrice(order);
        });
    });

    function sortByPrice(order) {
        var formData = $('#filter_form').serialize(); // Получаем данные формы
        formData += '&order=' + order; // Добавляем параметр сортировки по цене

        $.ajax({
            url: window.location.href, // URL текущей страницы
            type: 'GET',
            data: formData,
            success: function (response) {
                $('.cards').html($(response).find('.cards').html()); // Обновляем карточки товаров на странице

                // Re-initialize WooCommerce scripts if needed
                if (typeof wc_variation_form !== 'undefined') {
                    $('.variations_form').each(function () {
                        var $this = $(this);
                        if (!$this.data('wc_variation_form')) {
                            $this.wc_variation_form();
                        }
                    });
                }
            }
        });
    }
</script>
<script>
    document.addEventListener('DOMContentLoaded', function () {
        const customSelectWrapper = document.querySelector('.custom-select-wrapper');
        const trigger = customSelectWrapper.querySelector('.custom-select-trigger');
        const hiddenSelect = document.getElementById('sort_select');
        const options = document.querySelectorAll('.custom-options .custom-option');
        const optionsSecond = document.querySelectorAll('.custom-options-second .custom-option');
        const overlay = document.querySelector('.overlay');

        trigger.addEventListener('click', function () {
            if (window.innerWidth < 768) {
                document.querySelector('.custom-options-second').classList.toggle('open');
                overlay.style.display = 'block';
            } else {
                customSelectWrapper.querySelector('.custom-select').classList.toggle('open');
            }
        });

        function handleOptionClick(option, optionList) {
            optionList.forEach(opt => opt.classList.remove('selected'));
            option.classList.add('selected');
            trigger.querySelector('span').textContent = option.textContent;
            hiddenSelect.value = option.getAttribute('data-value');

            if (window.innerWidth < 768) {
                document.querySelector('.custom-options-second').classList.remove('open');
                overlay.style.display = 'none';
            } else {
                customSelectWrapper.querySelector('.custom-select').classList.remove('open');
            }

            // Call the sortByPrice function
            sortByPrice(hiddenSelect.value);
        }

        options.forEach(option => {
            option.addEventListener('click', function () {
                if (window.innerWidth >= 768) {
                    handleOptionClick(this, options);
                }
            });
        });

        optionsSecond.forEach(option => {
            option.addEventListener('click', function () {
                if (window.innerWidth < 768) {
                    handleOptionClick(this, optionsSecond);
                }
            });
        });

        window.addEventListener('click', function (e) {
            if (!customSelectWrapper.contains(e.target) && !document.querySelector('.custom-options-second').contains(e.target)) {
                customSelectWrapper.querySelector('.custom-select').classList.remove('open');
                document.querySelector('.custom-options-second').classList.remove('open');
                overlay.style.display = 'none';
            }
        });
    });
</script>
<script>
    document.addEventListener('DOMContentLoaded', function () {
        // Получаем параметры URL
        const urlParams = new URLSearchParams(window.location.search);
        const order = urlParams.get('order');

        // Определяем, какой элемент должен быть выбран
        let selectedOption;
        if (order === 'asc' || order === 'desc') {
            selectedOption = document.querySelector('.custom-option[data-value="' + order + '"]');
        } else if (order === 'sku') {
            selectedOption = document.querySelector('.custom-option[data-value="sku"]');
        }

        // Если выбрана опция, добавляем класс 'selected'
        if (selectedOption) {
            // Удаляем класс 'selected' у всех опций
            document.querySelectorAll('.custom-option').forEach(option => {
                option.classList.remove('selected');
            });

            // Добавляем класс 'selected' к выбранной опции
            selectedOption.classList.add('selected');

            // Обновляем текст триггера
            const triggerText = document.querySelector('.custom-select-trigger span');
            triggerText.textContent = selectedOption.textContent;
        }

        // Обработчики событий для опций
        document.querySelectorAll('.custom-option').forEach(option => {
            option.addEventListener('click', function () {
                const orderValue = this.getAttribute('data-value');
                const currentUrl = window.location.href;
                const newUrl = new URL(currentUrl);
                newUrl.searchParams.set('orderby', 'price');
                newUrl.searchParams.set('order', orderValue);
                window.location.href = newUrl.toString();
            });
        });
    });
</script>
